{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickDock",
  "version": "0.1.0",
  "identifier": "dev.rayat.quick-dock",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuickDock",
        "width": 340,
        "height": 700,
        "x": 0,
        "y": 0,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "dragDropEnabled": true
      },
      {
        "label": "edge",
        "title": "QuickDock Edge",
        "width": 2,
        "height": 2160,
        "x": 0,
        "y": 0,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "focus": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/**", "$APPDATA/**", "$APPLOCAL/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Zul Ikram Musaddik Rayat",
    "windows": {
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
